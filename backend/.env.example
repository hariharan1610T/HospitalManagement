PORT=5000
CORS_ORIGIN=http://localhost:5173

# Supabase (Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Required for registration and admin routes (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional email notification settings. Gmail requires an app password.
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=

# Optional WhatsApp notification settings through Twilio Sandbox or approved sender.
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
